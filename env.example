MEITY_API_KEY_VALUE=your_bhashini_api_key               # Bhashini API key
LLM_PROVIDER="gemini"                # Supported options: openai, vllm, openrouter
LLM_MODEL_NAME="gemini-3-flash-preview"    # Proven best model for tool calling
INFERENCE_ENDPOINT_URL=your_inference_endpoint_url_here # VLLM endpoint
INFERENCE_API_KEY=your_inference_api_key_here           # VLLM API key
MAPBOX_API_TOKEN=your_mapbox_token_here                 # Mapbox for geocoding
MARQO_ENDPOINT_URL=http://marqo:8882        # Vector DB (Marqo) Endpoint URL
MARQO_INDEX_NAME=your_marqo_index_name_here             # Vector DB (Marqo) Vector Index - Name
OPENAI_API_KEY=your_openai_api_key_here                 # OPENAI API KEY if LLM model is openai
BAP_ID=your_bap_id                                      #BAP_ID, api request payload
BAP_URI=your_bap_uri                                    #BAP_URI, api request payload
BAP_ENDPOINT=your_api_endpoint                          #API endpoint for weather, mandi, warehouse and scheme
GEMINI_API_KEY="AIzaSyB8Iv3YgCZes3MEIZXjKcJnoSq5JfKxNm0"
NOMINATIM_DOMAIN="74.225.15.164"      # Nominatim domain for geocoding
OPENWEATHERMAP_API_KEY="6cff114a26a521ecbb89a33a26087eb4"

# Redis Configuration
REDIS_HOST=redis-stack
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://oan_user:oan_password@postgres:5432/oan_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Data Scraper Configuration
SCRAPER_ENABLED=true

# Azure Configuration
azure_foundary_api_key="your_azure_key_here" #SulopaKey
azure_foundary_region="centralindia"

# Moderation Settings
# Set to 'true' to enable moderation (adds ~3.5 seconds per request)
# Old backend doesn't have moderation, so default is 'false'
ENABLE_MODERATION=false

# Suggestions Settings
# Set to 'true' to enable parallel suggestions agent (may add 1-5 seconds)
# Set to 'false' to disable suggestions for faster responses
ENABLE_SUGGESTIONS=false

